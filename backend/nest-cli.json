{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/gateway/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/gateway",
  "projects": {
    "building": {
      "type": "application",
      "root": "apps/building",
      "entryFile": "main",
      "sourceRoot": "apps/building/src",
      "compilerOptions": {
        "tsConfigPath": "apps/building/tsconfig.app.json"
      }
    },
    "gateway": {
      "type": "application",
      "root": "apps/gateway",
      "entryFile": "main",
      "sourceRoot": "apps/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gateway/tsconfig.app.json"
      }
    },
    "parameter": {
      "type": "application",
      "root": "apps/parameter",
      "entryFile": "main",
      "sourceRoot": "apps/parameter/src",
      "compilerOptions": {
        "tsConfigPath": "apps/parameter/tsconfig.app.json"
      }
    },
    "request": {
      "type": "application",
      "root": "apps/request",
      "entryFile": "main",
      "sourceRoot": "apps/request/src",
      "compilerOptions": {
        "tsConfigPath": "apps/request/tsconfig.app.json"
      }
    },
    "reservation": {
      "type": "application",
      "root": "apps/reservation",
      "entryFile": "main",
      "sourceRoot": "apps/reservation/src",
      "compilerOptions": {
        "tsConfigPath": "apps/reservation/tsconfig.app.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    },
    "user": {
      "type": "application",
      "root": "apps/user",
      "entryFile": "main",
      "sourceRoot": "apps/user/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user/tsconfig.app.json"
      }
    }
  }
}